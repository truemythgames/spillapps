---
import Base from "../../layouts/Base.astro";
import { getCharacters, APP_STORE_URL } from "../../lib/stories";

const characters = await getCharacters();

const title = "Bible Characters — History Tea";
const description = `Meet ${characters.length} Bible characters from Adam to Paul. Explore their stories as immersive audio on History Tea.`;

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Bible Characters",
  description,
  url: "https://historytea.app/characters",
  publisher: {
    "@type": "Organization",
    name: "History Tea",
    logo: { "@type": "ImageObject", url: "https://historytea.app/icon.png" },
  },
};

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Bible Characters",
  numberOfItems: characters.length,
  itemListElement: characters.map((ch, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: ch.name,
    url: `https://historytea.app/characters/${ch.id}`,
    description: ch.description,
  })),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://historytea.app" },
    { "@type": "ListItem", position: 2, name: "Bible Characters", item: "https://historytea.app/characters" },
  ],
};

const faqs = [
  {
    q: "Who are the main characters in the Bible?",
    a: `History Tea features ${characters.length} key Bible characters including ${characters.slice(0, 6).map((c) => c.name).join(", ")} and more. Each character page links to the stories they appear in, available as free immersive audio.`,
  },
  {
    q: "Can I listen to Bible character stories for free?",
    a: "Yes! Every character story on History Tea is completely free. Download the app on iOS and listen to any character's full story arc with professional narration.",
  },
  {
    q: "How many Bible characters does History Tea cover?",
    a: `History Tea currently features ${characters.length} characters from the Old and New Testaments, from Adam and Eve to the apostles Peter and Paul.`,
  },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const jsonLdArray = [collectionLd, itemListLd, breadcrumbLd, faqLd];
---

<Base
  title={title}
  description={description}
  canonicalPath="/characters"
  jsonLd={jsonLdArray}
>
  <style>
    .characters-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 7rem 2rem 0;
    }

    .page-hero {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 3rem;
    }

    .page-hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      margin-bottom: 0.75rem;
      background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .page-hero p {
      color: var(--text-secondary);
      font-size: 1.1rem;
      line-height: 1.7;
    }

    .characters-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .char-card {
      text-decoration: none;
      text-align: center;
      transition: transform 0.25s;
    }

    .char-card:hover { transform: translateY(-6px); }

    .char-avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      margin: 0 auto 0.75rem;
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.4);
      border: 3px solid var(--surface-border);
      display: block;
      transition: border-color 0.2s;
    }

    .char-card:hover .char-avatar { border-color: var(--primary); }

    .char-avatar-ph {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      margin: 0 auto 0.75rem;
      background: var(--surface-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
      border: 3px solid var(--surface-border);
    }

    .char-name {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: var(--text);
      margin-bottom: 0.2rem;
    }

    .char-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.3;
    }

    .char-count {
      font-size: 0.7rem;
      color: var(--accent);
      font-weight: 600;
      margin-top: 0.15rem;
    }

    .faq-section { max-width: 700px; margin: 0 auto; padding: 3rem 2rem; border-top: 1px solid var(--surface-border); }
    .faq-section h2 { font-family: 'Playfair Display', serif; font-size: 1.5rem; margin-bottom: 1.25rem; }
    .faq-item { background: var(--surface); border: 1px solid var(--surface-border); border-radius: 12px; margin-bottom: 0.6rem; overflow: hidden; transition: border-color 0.2s; }
    .faq-item:hover { border-color: var(--primary); }
    .faq-item[open] { border-color: rgba(200, 162, 255, 0.3); }
    .faq-item summary { padding: 1rem 1.25rem; cursor: pointer; font-weight: 600; font-size: 0.95rem; color: var(--text); list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; font-size: 1.25rem; color: var(--primary); flex-shrink: 0; }
    .faq-item[open] summary::after { content: '−'; }
    .faq-item p { padding: 0 1.25rem 1rem; color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7; }

    .bottom-cta { text-align: center; padding: 4rem 2rem 3rem; }
    .bottom-cta h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 0.75rem; }
    .bottom-cta p { color: var(--text-secondary); margin-bottom: 1.5rem; max-width: 450px; margin-left: auto; margin-right: auto; }
    .hero-cta { display: inline-flex; align-items: center; gap: 0.6rem; background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end)); color: #fff; padding: 0.8rem 2rem; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 24px rgba(200, 162, 255, 0.2); }
    .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(200, 162, 255, 0.35); }
    .hero-cta svg { width: 18px; height: 18px; }

    @media (max-width: 640px) {
      .characters-page { padding: 6rem 1.5rem 0; }
      .characters-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 1.5rem; }
      .char-avatar, .char-avatar-ph { width: 100px; height: 100px; }
    }
  </style>

  <main>
    <div class="characters-page">
      <div class="page-hero">
        <h1>Bible Characters</h1>
        <p>Meet {characters.length} characters from Genesis to Revelation. Explore their stories as immersive audio.</p>
      </div>

      <div class="characters-grid">
        {characters.map((ch) => (
          <a href={`/characters/${ch.id}`} class="char-card">
            {ch.image_url ? (
              <img src={ch.image_url} alt={ch.name} class="char-avatar" loading="lazy" />
            ) : (
              <div class="char-avatar-ph">👤</div>
            )}
            <div class="char-name">{ch.name}</div>
            <div class="char-desc">{ch.description}</div>
            {ch.stories.length > 0 && (
              <div class="char-count">{ch.stories.length} {ch.stories.length === 1 ? "story" : "stories"}</div>
            )}
          </a>
        ))}
      </div>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    <section class="bottom-cta">
      <h2>Hear Their Stories</h2>
      <p>Download History Tea and listen to every character's story with immersive audio narration.</p>
      <a href={APP_STORE_URL} class="hero-cta">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        Download for iOS
      </a>
    </section>
  </main>
</Base>
