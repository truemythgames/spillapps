---
import Base from "../../layouts/Base.astro";
import {
  getCatalog,
  getPlaylists,
  hasCover,
  coverUrl,
  APP_STORE_URL,
  type Playlist,
} from "../../lib/stories";

export async function getStaticPaths() {
  const catalog = getCatalog();
  const playlists = await getPlaylists(catalog);
  return playlists.map((pl) => ({
    params: { id: pl.id },
    props: { playlist: pl, allPlaylists: playlists },
  }));
}

interface Props {
  playlist: Playlist;
  allPlaylists: Playlist[];
}

const { playlist, allPlaylists } = Astro.props;
const stories = playlist.stories;

const pageTitle = `${playlist.name} — Bible Stories | History Tea`;
const pageDesc = `${playlist.description} Listen to ${stories.length} stories in the ${playlist.name} collection on History Tea.`;
const pageUrl = `https://historytea.app/playlists/${playlist.id}`;

const firstCover = stories.find((s) => hasCover(s.id));
const ogImage = firstCover ? coverUrl(firstCover.id) : "https://historytea.app/icon.png";

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: playlist.name,
  description: playlist.description,
  url: pageUrl,
  numberOfItems: stories.length,
  publisher: {
    "@type": "Organization",
    name: "History Tea",
    logo: { "@type": "ImageObject", url: "https://historytea.app/icon.png" },
  },
};

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: playlist.name,
  description: playlist.description,
  numberOfItems: stories.length,
  itemListElement: stories.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: s.title,
    url: `https://historytea.app/stories/${s.id}`,
    description: s.description,
  })),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://historytea.app" },
    { "@type": "ListItem", position: 2, name: "Playlists", item: "https://historytea.app/playlists" },
    { "@type": "ListItem", position: 3, name: playlist.name, item: pageUrl },
  ],
};

const faqs = [
  {
    q: `What stories are in the ${playlist.name} collection?`,
    a: `The ${playlist.name} collection includes ${stories.length} stories: ${stories.slice(0, 5).map((s) => s.title).join(", ")}${stories.length > 5 ? `, and ${stories.length - 5} more` : ""}. All available as immersive audio on History Tea.`,
  },
  {
    q: `Can I listen to ${playlist.name} stories for free?`,
    a: `Yes! All ${stories.length} stories in the ${playlist.name} collection are completely free to listen to on the History Tea app. Download on iOS and start listening today.`,
  },
  {
    q: `What Bible chapters does ${playlist.name} cover?`,
    a: `The ${playlist.name} collection covers ${stories.slice(0, 4).map((s) => s.bibleRef).join(", ")}${stories.length > 4 ? " and more" : ""}. Each story is a modern retelling with immersive narration.`,
  },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const jsonLdArray = [collectionLd, itemListLd, breadcrumbLd, faqLd];

const otherPlaylists = allPlaylists.filter((p) => p.id !== playlist.id).slice(0, 6);
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={ogImage}
  canonicalPath={`/playlists/${playlist.id}`}
  jsonLd={jsonLdArray}
>
  <style>
    .playlist-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 7rem 2rem 0;
    }

    .breadcrumbs {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    .breadcrumbs a {
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .breadcrumbs a:hover { color: var(--primary); }
    .breadcrumbs .sep { opacity: 0.4; }

    .playlist-hero {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 3rem;
    }

    .playlist-hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      margin-bottom: 0.75rem;
      background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .playlist-hero p {
      color: var(--text-secondary);
      font-size: 1.1rem;
      line-height: 1.7;
      margin-bottom: 0.5rem;
    }

    .playlist-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      color: #fff;
      padding: 0.8rem 2rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 24px rgba(200, 162, 255, 0.2);
    }

    .hero-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(200, 162, 255, 0.35);
    }

    .hero-cta svg { width: 18px; height: 18px; }

    .stories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .story-card {
      text-decoration: none;
      transition: transform 0.25s;
    }

    .story-card:hover { transform: translateY(-6px) scale(1.02); }

    .card-cover {
      width: 100%;
      aspect-ratio: 1;
      border-radius: 14px;
      overflow: hidden;
      position: relative;
      margin-bottom: 0.6rem;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    }

    .card-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .card-cover-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, var(--surface) 0%, var(--surface-light) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
    }

    .card-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 0.5rem 0.65rem;
      background: linear-gradient(transparent, rgba(0,0,0,0.8));
    }

    .card-ref {
      font-size: 0.65rem;
      color: var(--accent);
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.25;
      margin-top: 0.2rem;
    }

    .card-desc {
      font-size: 0.75rem;
      color: var(--text-muted);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-top: 0.2rem;
    }

    .faq-section {
      max-width: 700px;
      margin: 0 auto;
      padding: 3rem 0;
      border-top: 1px solid var(--surface-border);
    }

    .faq-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.35rem;
      margin-bottom: 1rem;
    }

    .faq-item {
      background: var(--surface);
      border: 1px solid var(--surface-border);
      border-radius: 12px;
      margin-bottom: 0.6rem;
      overflow: hidden;
      transition: border-color 0.2s;
    }

    .faq-item:hover { border-color: var(--primary); }
    .faq-item[open] { border-color: rgba(200, 162, 255, 0.3); }

    .faq-item summary {
      padding: 1rem 1.25rem;
      cursor: pointer;
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text);
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .faq-item summary::-webkit-details-marker { display: none; }

    .faq-item summary::after {
      content: '+';
      font-size: 1.25rem;
      color: var(--primary);
      flex-shrink: 0;
    }

    .faq-item[open] summary::after { content: '−'; }

    .faq-item p {
      padding: 0 1.25rem 1rem;
      color: var(--text-secondary);
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .more-playlists {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3rem 2rem;
      border-top: 1px solid var(--surface-border);
    }

    .more-playlists h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.35rem;
      margin-bottom: 1.25rem;
    }

    .playlists-row {
      display: flex;
      gap: 1.25rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 0.75rem;
      scrollbar-width: none;
    }

    .playlists-row::-webkit-scrollbar { display: none; }

    .playlist-card {
      flex-shrink: 0;
      width: 220px;
      scroll-snap-align: start;
      text-decoration: none;
      background: var(--surface);
      border: 1px solid var(--surface-border);
      border-radius: 16px;
      padding: 1.5rem;
      transition: transform 0.2s, border-color 0.2s;
    }

    .playlist-card:hover {
      transform: translateY(-4px);
      border-color: var(--primary);
    }

    .pc-name {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: var(--text);
      margin-bottom: 0.35rem;
    }

    .pc-count {
      font-size: 0.75rem;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .pc-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .bottom-cta {
      text-align: center;
      padding: 4rem 2rem 3rem;
    }

    .bottom-cta h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.5rem, 3vw, 2rem);
      margin-bottom: 0.75rem;
    }

    .bottom-cta p {
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
      max-width: 450px;
      margin-left: auto;
      margin-right: auto;
    }

    @media (max-width: 640px) {
      .playlist-page { padding: 6rem 1.5rem 0; }
      .stories-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1rem; }
      .more-playlists { padding: 2rem 1.5rem; }
      .playlist-card { width: 180px; padding: 1.25rem; }
    }
  </style>

  <main>
    <div class="playlist-page">
      <div class="breadcrumbs">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <a href="/playlists">Playlists</a>
        <span class="sep">/</span>
        <span>{playlist.name}</span>
      </div>

      <div class="playlist-hero">
        <h1>{playlist.name}</h1>
        <p>{playlist.description}</p>
        <p class="playlist-meta">{stories.length} stories</p>
        <a href={APP_STORE_URL} class="hero-cta">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          Listen to This Collection
        </a>
      </div>

      <div class="stories-grid">
        {stories.map((s) => (
          <a href={`/stories/${s.id}`} class="story-card">
            <div class="card-cover">
              {hasCover(s.id) ? (
                <img src={coverUrl(s.id)} alt={s.title} loading="lazy" />
              ) : (
                <div class="card-cover-placeholder">📖</div>
              )}
              <div class="card-overlay">
                <div class="card-ref">{s.bibleRef}</div>
              </div>
            </div>
            <div class="card-title">{s.title}</div>
            <div class="card-desc">{s.description}</div>
          </a>
        ))}
      </div>
    </div>

    <section class="faq-section" style="max-width:700px;margin:0 auto;padding:3rem 2rem;">
      <h2>Frequently Asked Questions</h2>
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    {otherPlaylists.length > 0 && (
      <section class="more-playlists">
        <h2>More Collections</h2>
        <div class="playlists-row">
          {otherPlaylists.map((p) => (
            <a href={`/playlists/${p.id}`} class="playlist-card">
              <div class="pc-name">{p.name}</div>
              <div class="pc-count">{p.stories.length} stories</div>
              <div class="pc-desc">{p.description}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="bottom-cta">
      <h2>Ready to Listen?</h2>
      <p>Download History Tea and listen to every story in {playlist.name} with immersive narration.</p>
      <a href={APP_STORE_URL} class="hero-cta">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        Download for iOS
      </a>
    </section>
  </main>
</Base>
