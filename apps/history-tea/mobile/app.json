{
  "expo": {
    "name": "History Tea",
    "slug": "historytea",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "historytea",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06080F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.historytea",
      "buildNumber": "3",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06080F"
      },
      "package": "app.historytea",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#06080F",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      "./plugins/firebase-modular-headers",
      "./plugins/hermes-dsym-plugin",
      "./plugins/now-playing-plugin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.spillapps.com",
      "appId": "history-tea",
      "googleWebClientId": "",
      "googleIosClientId": ""
    }
  }
}
