# Optional overrides at build time (EAS env or local). Values in app.json `extra` are defaults.
# Web client must match API GOOGLE_CLIENT_ID / CMS VITE_GOOGLE_CLIENT_ID.
EXPO_PUBLIC_API_URL=https://api.spillapps.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Create an iOS OAuth client in Google Cloud (iOS, bundle id app.historytea), then paste its client id:
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
