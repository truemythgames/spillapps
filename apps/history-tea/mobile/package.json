{
  "name": "@spillapps/history-tea-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules"
    }
  },
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --clear --localhost --go",
    "start:ios": "expo start --ios --localhost --go",
    "start:dev-client": "expo start --localhost --dev-client",
    "android": "expo run:android",
    "ios": "npx pod-install && expo run:ios",
    "ios:sim": "npx pod-install && expo run:ios --device \"iPhone 16\"",
    "prebuild": "expo prebuild",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/playfair-display": "^0.2.3",
    "@react-native-async-storage/async-storage": "~2.1.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "~53.0.0",
    "expo-apple-authentication": "~7.2.4",
    "expo-av": "~15.1.0",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.0",
    "expo-haptics": "~14.1.0",
    "expo-image": "~2.4.0",
    "expo-linear-gradient": "~14.1.0",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.0",
    "expo-secure-store": "~14.2.0",
    "expo-splash-screen": "~0.30.0",
    "expo-status-bar": "~2.2.0",
    "expo-store-review": "~8.1.5",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-purchases": "^9.15.1",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.0",
    "typescript": "~5.8.0"
  }
}
