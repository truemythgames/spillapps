# Copy to .env for local CMS. Vite loads VITE_* only at build time.
# Optional: override API host. If unset in dev, CMS uses http://localhost:8787 (run wrangler dev).
# Set this to https://api.spillapps.com to sign in against production while Vite runs locally.
# VITE_API_BASE_URL=https://api.spillapps.com
VITE_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
VITE_APP_ID=bible-tea
# Multi-product CMS: comma-separated ids (must match Worker ALLOWED_APP_IDS). Omit to use VITE_APP_ID only.
# VITE_ALLOWED_APP_IDS=bible-tea,other-tea
# Optional: only this Google email may sign in (case-insensitive). Omit entirely to allow any Google account.
# VITE_ALLOWED_EMAIL=you@example.com
