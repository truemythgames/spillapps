---
import Base from "../../layouts/Base.astro";
import StoreButtons from "../../components/StoreButtons.astro";
import {
  getSeasons,
  hasCover,
  coverUrl,
  type Season,
} from "../../lib/stories";

export async function getStaticPaths() {
  const seasons = await getSeasons();
  return seasons.map((season) => ({
    params: { slug: season.slug },
    props: { season, allSeasons: seasons },
  }));
}

interface Props {
  season: Season;
  allSeasons: Season[];
}

const { season, allSeasons } = Astro.props;
const stories = season.stories;

const pageTitle = `${season.name} Bible Stories — Listen Free | Bible Tea`;
const pageDesc = `${season.description || `Explore every story from ${season.name}.`} Listen to ${stories.length} ${season.name} stories as immersive audio on Bible Tea.`;
const pageUrl = `https://bibletea.app/books/${season.slug}`;
const ogImage = season.cover_image_url || "https://bibletea.app/icon.png";

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${season.name} Bible Stories`,
  description: pageDesc,
  url: pageUrl,
  numberOfItems: stories.length,
  publisher: {
    "@type": "Organization",
    name: "Bible Tea",
    logo: { "@type": "ImageObject", url: "https://bibletea.app/icon.png" },
  },
};

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${season.name} Stories`,
  description: pageDesc,
  numberOfItems: stories.length,
  itemListElement: stories.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: s.title,
    url: `https://bibletea.app/stories/${s.slug}`,
    description: s.description,
  })),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://bibletea.app" },
    { "@type": "ListItem", position: 2, name: "Bible Stories", item: "https://bibletea.app/stories" },
    { "@type": "ListItem", position: 3, name: season.name, item: pageUrl },
  ],
};

const faqs = [
  {
    q: `What stories are in the Book of ${season.name}?`,
    a: `Bible Tea covers ${stories.length} stories from ${season.name}, including ${stories.slice(0, 4).map((s) => s.title).join(", ")}${stories.length > 4 ? ` and ${stories.length - 4} more` : ""}. Each story is available as immersive audio narration.`,
  },
  {
    q: `Can I listen to ${season.name} stories for free?`,
    a: `Yes! All ${stories.length} ${season.name} stories on Bible Tea are completely free. Download the app on iOS or Android and start listening today.`,
  },
  {
    q: `What is the Book of ${season.name} about?`,
    a: season.description
      ? `${season.description} Bible Tea retells each story from ${season.name} as modern, immersive audio you can listen to anywhere.`
      : `The Book of ${season.name} contains some of the most well-known stories in the Bible. Bible Tea brings each one to life as immersive audio narration.`,
  },
  {
    q: `How long are the ${season.name} audio stories?`,
    a: `Each ${season.name} story on Bible Tea runs between 5-15 minutes of immersive audio narration — perfect for a commute, workout, or before bed.`,
  },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const jsonLdArray = [collectionLd, itemListLd, breadcrumbLd, faqLd];

const otherSeasons = allSeasons.filter((s) => s.id !== season.id);
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={ogImage}
  canonicalPath={`/books/${season.slug}`}
  jsonLd={jsonLdArray}
>
  <style>
    .book-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 7rem 2rem 0;
    }

    .breadcrumbs {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    .breadcrumbs a {
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .breadcrumbs a:hover { color: var(--primary); }
    .breadcrumbs .sep { opacity: 0.4; }

    .book-hero {
      display: flex;
      gap: 2.5rem;
      align-items: center;
      max-width: 800px;
      margin: 0 auto 3rem;
    }

    .book-cover {
      width: 200px;
      height: 200px;
      border-radius: 18px;
      object-fit: cover;
      flex-shrink: 0;
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);
    }

    .book-cover-ph {
      width: 200px;
      height: 200px;
      border-radius: 18px;
      flex-shrink: 0;
      background: linear-gradient(135deg, var(--surface-light) 0%, var(--surface) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3.5rem;
    }

    .book-info { flex: 1; min-width: 0; }

    .book-testament {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 600;
      color: var(--accent);
      margin-bottom: 0.4rem;
    }

    .book-info h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      line-height: 1.15;
      margin-bottom: 0.6rem;
    }

    .book-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .book-desc {
      color: var(--text-secondary);
      font-size: 1rem;
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      color: #fff;
      padding: 0.8rem 2rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 24px rgba(200, 162, 255, 0.2);
    }

    .hero-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(200, 162, 255, 0.35);
    }

    .hero-cta svg { width: 18px; height: 18px; }

    .stories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .story-card { text-decoration: none; transition: transform 0.25s; }
    .story-card:hover { transform: translateY(-6px) scale(1.02); }

    .card-cover {
      width: 100%;
      aspect-ratio: 1;
      border-radius: 14px;
      overflow: hidden;
      position: relative;
      margin-bottom: 0.6rem;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    }

    .card-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .card-cover-placeholder {
      width: 100%; height: 100%;
      background: linear-gradient(135deg, var(--surface) 0%, var(--surface-light) 100%);
      display: flex; align-items: center; justify-content: center; font-size: 2.5rem;
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.9rem; font-weight: 700;
      color: var(--text); line-height: 1.25; margin-top: 0.2rem;
    }

    .card-desc {
      font-size: 0.75rem; color: var(--text-muted); line-height: 1.4;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
      margin-top: 0.2rem;
    }

    .card-duration {
      font-size: 0.65rem; color: var(--accent); font-weight: 600; margin-top: 0.15rem;
    }

    .faq-section { max-width: 700px; margin: 0 auto; padding: 3rem 2rem; border-top: 1px solid var(--surface-border); }
    .faq-section h2 { font-family: 'Playfair Display', serif; font-size: 1.35rem; margin-bottom: 1rem; }

    .faq-item {
      background: var(--surface); border: 1px solid var(--surface-border);
      border-radius: 12px; margin-bottom: 0.6rem; overflow: hidden; transition: border-color 0.2s;
    }
    .faq-item:hover { border-color: var(--primary); }
    .faq-item[open] { border-color: rgba(200, 162, 255, 0.3); }

    .faq-item summary {
      padding: 1rem 1.25rem; cursor: pointer; font-weight: 600; font-size: 0.95rem;
      color: var(--text); list-style: none;
      display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; font-size: 1.25rem; color: var(--primary); flex-shrink: 0; }
    .faq-item[open] summary::after { content: '−'; }
    .faq-item p { padding: 0 1.25rem 1rem; color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7; }

    .other-books { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem; border-top: 1px solid var(--surface-border); }
    .other-books h2 { font-family: 'Playfair Display', serif; font-size: 1.35rem; margin-bottom: 1.25rem; }

    .books-row {
      display: flex; gap: 1.25rem; overflow-x: auto; scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch; padding-bottom: 0.75rem; scrollbar-width: none;
    }
    .books-row::-webkit-scrollbar { display: none; }

    .book-card {
      flex-shrink: 0; width: 220px; scroll-snap-align: start; text-decoration: none;
      background: var(--surface); border: 1px solid var(--surface-border);
      border-radius: 16px; overflow: hidden; transition: transform 0.2s, border-color 0.2s;
    }
    .book-card:hover { transform: translateY(-4px); border-color: var(--primary); }
    .book-card-img { width: 100%; height: 120px; object-fit: cover; }
    .book-card-body { padding: 1rem; }
    .book-card-name { font-family: 'Playfair Display', serif; font-size: 1rem; color: var(--text); margin-bottom: 0.25rem; }
    .book-card-count { font-size: 0.75rem; color: var(--accent); font-weight: 600; }

    .bottom-cta { text-align: center; padding: 4rem 2rem 3rem; }
    .bottom-cta h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 0.75rem; }
    .bottom-cta p { color: var(--text-secondary); margin-bottom: 1.5rem; max-width: 450px; margin-left: auto; margin-right: auto; }

    @media (max-width: 640px) {
      .book-page { padding: 6rem 1.5rem 0; }
      .book-hero { flex-direction: column; text-align: center; gap: 1.5rem; }
      .book-cover, .book-cover-ph { width: 160px; height: 160px; }
      .stories-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1rem; }
      .other-books { padding: 2rem 1.5rem; }
      .book-card { width: 180px; }
    }
  </style>

  <main>
    <div class="book-page">
      <div class="breadcrumbs">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <a href="/stories">Stories</a>
        <span class="sep">/</span>
        <span>{season.name}</span>
      </div>

      <div class="book-hero">
        {season.cover_image_url ? (
          <img src={season.cover_image_url} alt={season.name} class="book-cover" loading="eager" />
        ) : (
          <div class="book-cover-ph">📖</div>
        )}
        <div class="book-info">
          <div class="book-testament">{season.testament} Testament</div>
          <h1>{season.name}</h1>
          <p class="book-meta">{stories.length} stories</p>
          {season.description && <p class="book-desc">{season.description}</p>}
          <StoreButtons variant="hero" />
        </div>
      </div>

      <div class="stories-grid">
        {stories.map((s) => (
          <a href={`/stories/${s.slug}`} class="story-card">
            <div class="card-cover">
              {s.cover_image_url ? (
                <img src={s.cover_image_url} alt={s.title} loading="lazy" />
              ) : (
                <div class="card-cover-placeholder">📖</div>
              )}
            </div>
            <div class="card-title">{s.title}</div>
            <div class="card-desc">{s.description}</div>
            {s.duration_seconds && (
              <div class="card-duration">{Math.round(s.duration_seconds / 60)} min</div>
            )}
          </a>
        ))}
      </div>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    {otherSeasons.length > 0 && (
      <section class="other-books">
        <h2>More Books</h2>
        <div class="books-row">
          {otherSeasons.map((s) => (
            <a href={`/books/${s.slug}`} class="book-card">
              {s.cover_image_url ? (
                <img src={s.cover_image_url} alt={s.name} class="book-card-img" loading="lazy" />
              ) : (
                <div class="book-card-img" style="background:var(--surface-light);display:flex;align-items:center;justify-content:center;font-size:2rem;">📖</div>
              )}
              <div class="book-card-body">
                <div class="book-card-name">{s.name}</div>
                <div class="book-card-count">{s.stories.length} stories</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="bottom-cta">
      <h2>Ready to Listen?</h2>
      <p>Download Bible Tea and listen to every {season.name} story with immersive narration.</p>
      <StoreButtons variant="hero" />
    </section>
  </main>
</Base>
