---
import Base from "../layouts/Base.astro";

const title = "Page Not Found — Bible Tea";
const description = "The page you're looking for doesn't exist.";
---

<Base title={title} description={description}>
  <style>
    .not-found {
      min-height: 80vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 8rem 2rem 4rem;
    }
    .not-found h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 8vw, 6rem);
      background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1rem;
    }
    .not-found p {
      color: var(--text-secondary);
      font-size: 1.15rem;
      max-width: 400px;
      margin-bottom: 2.5rem;
    }
    .not-found-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
    }
    .not-found-links a {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.75rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .not-found-links a:hover {
      transform: translateY(-2px);
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      color: #fff;
      box-shadow: 0 4px 20px rgba(200, 162, 255, 0.2);
    }
    .btn-primary:hover {
      box-shadow: 0 8px 30px rgba(200, 162, 255, 0.35);
    }
    .btn-ghost {
      border: 1px solid var(--surface-border);
      color: var(--text-secondary);
    }
    .btn-ghost:hover {
      border-color: var(--primary);
      color: var(--primary);
    }
  </style>

  <div class="not-found">
    <h1>404</h1>
    <p>This page doesn't exist. Maybe the story you're looking for is somewhere else.</p>
    <div class="not-found-links">
      <a href="/" class="btn-primary">Go Home</a>
      <a href="/stories" class="btn-ghost">Browse Stories</a>
    </div>
  </div>
</Base>
