---
import Base from "../layouts/Base.astro";
import { APP_STORE_URL, MEDIA_BASE } from "../lib/stories";

const title = "Bible Tea: Bible Storycast — Spill the tea. Read the Bible.";
const description = "Bible stories reimagined as immersive audio experiences. Spill the tea. Read the Bible.";

const homeLd = {
  "@context": "https://schema.org",
  "@type": "MobileApplication",
  name: "Bible Tea",
  operatingSystem: "iOS",
  applicationCategory: "ReligionApplication",
  url: "https://bibletea.app",
  image: "https://bibletea.app/icon.png",
  description,
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5",
    ratingCount: "50",
    bestRating: "5",
  },
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};

const storyCards = [
  { id: "creation", title: "Creation", ref: "Genesis 1-2" },
  { id: "adam-and-eve", title: "Adam & Eve", ref: "Genesis 2-3" },
  { id: "david-and-goliath", title: "David & Goliath", ref: "1 Samuel 17" },
  { id: "jonah-and-the-whale", title: "Jonah & the Whale", ref: "Jonah 1-4" },
  { id: "the-prodigal-son", title: "The Prodigal Son", ref: "Luke 15:11-32" },
  { id: "crossing-the-red-sea", title: "Crossing the Red Sea", ref: "Exodus 14" },
  { id: "daniel-and-the-lions-den", title: "Daniel & the Lions", ref: "Daniel 6" },
  { id: "the-resurrection", title: "The Resurrection", ref: "Matthew 28" },
  { id: "samson-and-delilah", title: "Samson & Delilah", ref: "Judges 16" },
  { id: "ruth-and-naomi", title: "Ruth & Naomi", ref: "Ruth 1-4" },
];

const playlistCards = [
  { cover: "creation", name: "Start Here" },
  { cover: "the-last-supper", name: "Holy Week" },
  { cover: "adam-and-eve", name: "Love Stories" },
  { cover: "crossing-the-red-sea", name: "Miracles & Wonders" },
  { cover: "joseph-and-his-brothers", name: "Family Drama" },
  { cover: "the-resurrection", name: "The Jesus Story" },
  { cover: "daniel-and-the-lions-den", name: "Courage Under Fire" },
  { cover: "samson-and-delilah", name: "Maximum Drama" },
  { cover: "david-and-goliath", name: "Underdog Stories" },
];

const reviews = [
  { text: "This app completely changed how I engage with the Bible. The narrations are beautiful and the artwork for each story is stunning. I listen every morning with my coffee.", name: "Sarah M.", initial: "S", date: "March 2025" },
  { text: "Finally an app that makes Bible stories feel alive. My kids love listening to it before bed. The Story of the Day feature keeps us coming back every single day.", name: "James R.", initial: "J", date: "March 2025" },
  { text: "I've tried so many Bible apps and this is the first one that actually made me excited to open it. The playlists are perfectly curated and the audio quality is incredible.", name: "Maria L.", initial: "M", date: "April 2025" },
  { text: "Love the 'Spill the Tea' vibe — it makes scripture feel so approachable. I listen during my commute and it's become the best part of my day. Highly recommend!", name: "David K.", initial: "D", date: "April 2025" },
  { text: "The character profiles are such a smart feature. Following Moses across different stories gives you so much more context. Beautiful design too — dark mode is perfect.", name: "Anna T.", initial: "A", date: "March 2025" },
  { text: "As someone who grew up with these stories, hearing them narrated with such care and emotion brought tears to my eyes. This is how scripture should be experienced.", name: "Robert P.", initial: "R", date: "April 2025" },
];

const starSvg = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>`;
const appleSvg = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>`;
---

<Base title={title} description={description} canonicalPath="/" jsonLd={homeLd}>
  <style>
    /* Hero */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 8rem 2rem 4rem;
      position: relative;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(200, 162, 255, 0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-icon {
      width: 120px;
      height: 120px;
      border-radius: 28px;
      margin-bottom: 2rem;
      box-shadow: 0 20px 60px rgba(200, 162, 255, 0.15);
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      line-height: 1.1;
      margin-bottom: 1.25rem;
      background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: var(--text-secondary);
      max-width: 520px;
      margin: 0 auto 2rem;
      line-height: 1.7;
    }
    .hero-proof {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--accent);
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 2rem;
      letter-spacing: 0.02em;
    }
    .hero-proof :global(svg) { width: 16px; height: 16px; flex-shrink: 0; }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      color: #fff;
      padding: 1rem 2.5rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1.1rem;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 30px rgba(200, 162, 255, 0.2);
    }
    .hero-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 40px rgba(200, 162, 255, 0.35);
    }
    .hero-cta :global(svg) { width: 20px; height: 20px; }

    /* Showcase */
    .showcase { padding: 4rem 2rem; overflow: hidden; }
    .showcase-title {
      text-align: center;
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      margin-bottom: 0.75rem;
    }
    .showcase-sub {
      text-align: center;
      color: var(--text-secondary);
      margin-bottom: 3rem;
      font-size: 1rem;
    }
    .card-scroll {
      display: flex;
      gap: 1.25rem;
      animation: scroll-left 40s linear infinite;
      width: max-content;
    }
    .card-scroll:hover { animation-play-state: paused; }
    @keyframes scroll-left {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .card-scroll-reverse {
      display: flex;
      gap: 1.25rem;
      animation: scroll-right 45s linear infinite;
      width: max-content;
      margin-top: 1.5rem;
    }
    .card-scroll-reverse:hover { animation-play-state: paused; }
    @keyframes scroll-right {
      0% { transform: translateX(-50%); }
      100% { transform: translateX(0); }
    }
    .story-card {
      flex-shrink: 0;
      width: 200px;
      border-radius: 16px;
      overflow: hidden;
      background: var(--surface);
      border: 1px solid var(--surface-border);
      transition: transform 0.3s, border-color 0.3s;
    }
    .story-card:hover { transform: translateY(-4px); border-color: var(--primary); }
    .story-card img { width: 200px; height: 200px; object-fit: cover; display: block; }
    .story-card-body { padding: 1rem; }
    .story-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
    }
    .story-card-ref { font-size: 0.75rem; color: var(--text-muted); }
    .playlist-card {
      flex-shrink: 0;
      width: 240px;
      height: 120px;
      border-radius: 16px;
      overflow: hidden;
      position: relative;
      border: 1px solid var(--surface-border);
      transition: transform 0.3s, border-color 0.3s;
    }
    .playlist-card:hover { transform: translateY(-4px); border-color: var(--primary); }
    .playlist-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .playlist-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(10,10,15,0.75) 0%, rgba(10,10,15,0.4) 100%);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 1rem 1.25rem;
    }
    .playlist-label {
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--accent);
      margin-bottom: 0.2rem;
    }
    .playlist-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
    }

    /* Features */
    .features { padding: 6rem 2rem; max-width: 1000px; margin: 0 auto; }
    .features-title {
      text-align: center;
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      margin-bottom: 3rem;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .feature-card {
      background: var(--surface);
      border: 1px solid var(--surface-border);
      border-radius: 16px;
      padding: 2rem;
      transition: border-color 0.3s;
    }
    .feature-card:hover { border-color: rgba(200, 162, 255, 0.3); }
    .feature-icon { font-size: 2rem; margin-bottom: 1rem; }
    .feature-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
    }
    .feature-card p { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7; }

    /* Reviews */
    .reviews { padding: 6rem 2rem; max-width: 1000px; margin: 0 auto; }
    .reviews-title {
      text-align: center;
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      margin-bottom: 0.5rem;
    }
    .reviews-subtitle {
      text-align: center;
      color: var(--text-secondary);
      margin-bottom: 3rem;
      font-size: 1rem;
    }
    .reviews-stars {
      display: flex;
      justify-content: center;
      gap: 0.25rem;
      margin-bottom: 0.75rem;
      font-size: 1.25rem;
      color: var(--accent);
    }
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .review-card {
      background: var(--surface);
      border: 1px solid var(--surface-border);
      border-radius: 16px;
      padding: 1.75rem;
      transition: border-color 0.3s;
    }
    .review-card:hover { border-color: rgba(200, 162, 255, 0.3); }
    .review-stars { display: flex; gap: 2px; margin-bottom: 0.75rem; color: var(--accent); font-size: 0.9rem; }
    .review-text {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.7;
      margin-bottom: 1rem;
      font-style: italic;
    }
    .review-author { display: flex; align-items: center; gap: 0.75rem; }
    .review-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }
    .review-name { font-weight: 600; font-size: 0.9rem; color: var(--text); }
    .review-date { font-size: 0.75rem; color: var(--text-muted); }

    /* CTA */
    .cta-section { padding: 6rem 2rem; text-align: center; position: relative; }
    .cta-section::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 400px;
      background: radial-gradient(circle, rgba(107, 92, 231, 0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .cta-section h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); margin-bottom: 1rem; }
    .cta-section p { color: var(--text-secondary); margin-bottom: 2rem; font-size: 1.1rem; }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: #fff;
      color: #000;
      padding: 1rem 2.5rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1.1rem;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 40px rgba(255, 255, 255, 0.1); }
    .cta-btn :global(svg) { width: 20px; height: 20px; }

    /* Responsive */
    @media (max-width: 640px) {
      .hero { padding: 7rem 1.5rem 3rem; }
      .hero h1 { font-size: 2.25rem; }
      .hero-icon { width: 88px; height: 88px; border-radius: 20px; }
      .features { padding: 4rem 1.5rem; }
      .features-grid { grid-template-columns: 1fr; }
      .cta-section { padding: 4rem 1.5rem; }
      .story-card { width: 160px; }
      .story-card img { width: 160px; height: 160px; }
    }
  </style>

  <section class="hero">
    <img src="/icon-sm.png" alt="Bible Tea App Icon" class="hero-icon" width="120" height="120" />
    <h1 class="heading">Spill the tea.<br/>Read the Bible.</h1>
    <p class="hero-sub">Every Bible story — from Genesis to Revelation — retold as immersive audio you can listen to anywhere.</p>
    <div class="hero-proof">
      <Fragment set:html={starSvg} />
      <Fragment set:html={starSvg} />
      <Fragment set:html={starSvg} />
      <Fragment set:html={starSvg} />
      <Fragment set:html={starSvg} />
      5 stars on the App Store
    </div>
    <a href={APP_STORE_URL} class="hero-cta">
      <Fragment set:html={appleSvg} />
      Download on the App Store
    </a>
  </section>

  <section class="showcase">
    <h2 class="heading showcase-title">Explore Bible Stories</h2>
    <p class="showcase-sub">From Creation to Resurrection — every story told like never before.</p>
    <div style="overflow: hidden;">
      <div class="card-scroll" id="card-scroll">
        {storyCards.map((s) => (
          <div class="story-card">
            <img src={`${MEDIA_BASE}/stories/${s.id}/cover.webp`} alt={s.title} loading="lazy" decoding="async" width="200" height="200" />
            <div class="story-card-body">
              <div class="story-card-title">{s.title}</div>
              <div class="story-card-ref">{s.ref}</div>
            </div>
          </div>
        ))}
      </div>
      <div class="card-scroll-reverse" id="playlist-scroll">
        {playlistCards.map((p) => (
          <div class="playlist-card">
            <img src={`${MEDIA_BASE}/stories/${p.cover}/cover.webp`} alt={p.name} loading="lazy" decoding="async" width="240" height="120" />
            <div class="playlist-overlay">
              <div class="playlist-label">Playlist</div>
              <div class="playlist-name">{p.name}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="features">
    <h2 class="heading features-title">Why Bible Tea?</h2>
    <div class="features-grid">
      <div class="feature-card"><div class="feature-icon">🎧</div><h3>Immersive Audio</h3><p>Every Bible story narrated with rich, engaging audio that brings scripture to life. Listen while commuting, working out, or winding down.</p></div>
      <div class="feature-card"><div class="feature-icon">🎨</div><h3>Beautiful Artwork</h3><p>Each story features stunning, original cover art that captures the drama and emotion of the biblical narrative.</p></div>
      <div class="feature-card"><div class="feature-icon">📖</div><h3>Old & New Testament</h3><p>From Genesis to Revelation — explore stories from both testaments, organized by season and theme for easy discovery.</p></div>
      <div class="feature-card"><div class="feature-icon">👤</div><h3>Bible Characters</h3><p>Dive deep into the lives of Moses, David, Ruth, Paul, and more. Follow their journeys across multiple stories.</p></div>
      <div class="feature-card"><div class="feature-icon">🍵</div><h3>Curated Playlists</h3><p>Start with "Start Here" or explore themed collections like Love Stories, Miracles, and Courage Under Fire.</p></div>
      <div class="feature-card"><div class="feature-icon">🔥</div><h3>Daily Story</h3><p>A fresh Story of the Day every day to keep you inspired and engaged with scripture on a daily basis.</p></div>
    </div>
  </section>

  <section class="reviews">
    <h2 class="heading reviews-title">What Listeners Are Saying</h2>
    <div class="reviews-stars">★★★★★</div>
    <p class="reviews-subtitle">Rated 5 stars on the App Store</p>
    <div class="reviews-grid">
      {reviews.map((r) => (
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"{r.text}"</p>
          <div class="review-author">
            <div class="review-avatar">{r.initial}</div>
            <div>
              <div class="review-name">{r.name}</div>
              <div class="review-date">{r.date}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="cta-section">
    <h2 class="heading">Ready to Spill the Tea?</h2>
    <p>Download Bible Tea and experience the Bible like never before.</p>
    <a href={APP_STORE_URL} class="cta-btn">
      <Fragment set:html={appleSvg} />
      Download for iOS
    </a>
  </section>

  <script is:inline>
    const scroll = document.getElementById('card-scroll');
    if (scroll) scroll.innerHTML += scroll.innerHTML;
    const plScroll = document.getElementById('playlist-scroll');
    if (plScroll) plScroll.innerHTML += plScroll.innerHTML;
  </script>
</Base>
